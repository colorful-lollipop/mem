config("ohos_sa_mock_config") {
  include_dirs = [ "include" ]
}

config("ohos_sa_mock_threads_config") {
  cflags = [ "-pthread" ]
  ldflags = [ "-pthread" ]
}

source_set("ohos_sa_mock") {
  sources = [
    "src/iremote_broker_registry.cpp",
    "src/iremote_object.cpp",
    "src/mock_service_socket.cpp",
    "src/scm_rights.cpp",
    "src/system_ability_manager.cpp",
  ]
  public_configs = [ ":ohos_sa_mock_config" ]
  all_dependent_configs = [ ":ohos_sa_mock_threads_config" ]
}

executable("ohos_sa_mock_demo") {
  sources = [ "demo/sa_mock_demo.cpp" ]
  deps = [ ":ohos_sa_mock" ]
}

if (defined(ohos_sa_mock_enable_tests) && ohos_sa_mock_enable_tests) {
  template("ohos_sa_mock_test") {
    executable(target_name) {
      testonly = true
      sources = invoker.sources
      deps = [
        ":ohos_sa_mock",
        ohos_sa_mock_gtest_main_target,
      ]
      configs += [ ":ohos_sa_mock_config" ]
    }
  }

  ohos_sa_mock_test("ohos_sa_mock_headers_test") {
    sources = [ "tests/ohos_sa_headers_test.cpp" ]
  }

  ohos_sa_mock_test("ohos_sa_mock_remote_object_test") {
    sources = [ "tests/ohos_sa_remote_object_test.cpp" ]
  }

  ohos_sa_mock_test("ohos_sa_mock_registry_test") {
    sources = [ "tests/ohos_sa_registry_test.cpp" ]
  }

  ohos_sa_mock_test("ohos_sa_mock_load_callback_test") {
    sources = [ "tests/ohos_sa_load_callback_test.cpp" ]
  }
}
